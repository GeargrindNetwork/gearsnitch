# GearSnitch API Environment Variables
NODE_ENV=development
PORT=3001
API_VERSION=v1

# MongoDB Atlas
MONGODB_URI=mongodb+srv://gearsnitch-api:<password>@gearsnitch-dev.sqrsvda.mongodb.net/gearsnitch?retryWrites=true&w=majority

# Redis
REDIS_URL=redis://localhost:6379

# JWT (RS256)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Google OAuth
# Comma-separated list of accepted ID token audiences across iOS and web.
GOOGLE_OAUTH_CLIENT_IDS=
# Legacy single-audience fallback. Safe to leave empty when GOOGLE_OAUTH_CLIENT_IDS is set.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Apple Sign In
# Comma-separated list of accepted Apple audiences (for example app bundle ID + web Services ID).
APPLE_CLIENT_IDS=
# Legacy single-audience fallback. Safe to leave empty when APPLE_CLIENT_IDS is set.
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# APNs
APNS_KEY=
APNS_KEY_ID=
APNS_TEAM_ID=

# Encryption
ENCRYPTION_KEY=

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=debug
